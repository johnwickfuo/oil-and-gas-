# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Display name used in the UI, emails and meta tags.
APP_NAME="Blue Dine Cuisines"
# Environment: local | staging | production
APP_ENV=local
# Generate with `php artisan key:generate`. Required.
APP_KEY=
# Set to false in production to hide stack traces.
APP_DEBUG=true
# Canonical base URL used for routing and mail links.
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Africa/Lagos

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database (MySQL 8 on Contabo VPS with HestiaCP)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bluedine
DB_USERNAME=bluedine
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Sessions, Cache and Queues
# Phase 1 uses the database driver across the board so a stock MySQL install
# on Hestia is enough to run the app. Redis can be introduced later.
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# Mail
# Configure with your SMTP provider (e.g. HestiaCP mail, Postmark, Resend).
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@bluedinecuisines.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# WhatsApp
# VITE_* is exposed to the Vue frontend (floating button href).
# The non-prefixed variable is available to the Laravel backend.
# Use the international format without the leading "+" (e.g. 2348012345678).
# -----------------------------------------------------------------------------
VITE_WHATSAPP_NUMBER=2348000000000
WHATSAPP_NUMBER=2348000000000

# -----------------------------------------------------------------------------
# Payments - Paystack (primary processor for Nigerian cards / transfers)
# -----------------------------------------------------------------------------
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# -----------------------------------------------------------------------------
# Payments - Flutterwave (secondary / fallback processor)
# -----------------------------------------------------------------------------
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Business rules
# Percentage of a booking total that must be paid as a deposit to confirm it.
# -----------------------------------------------------------------------------
DEPOSIT_PERCENTAGE=30

# -----------------------------------------------------------------------------
# Vite
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
